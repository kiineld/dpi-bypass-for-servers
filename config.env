# dpi-bypass configuration
# Edit these values, commit, and re-run `dpibypass` (or the one-line installer).

# --- zapret2 source (the DPI-bypass engine, built from source on each node) ---
ZAPRET_REPO="https://github.com/bol-van/zapret2"
ZAPRET_REF="main"
ZAPRET_BASE="/opt/zapret2"

# --- ports of your node-to-node links (VLESS/Reality, Shadowsocks, Hysteria) ---
# These are the ports the DPI-bypass is applied to. Comma-separated, no spaces.
PORTS_TCP="443,1443,8443"
PORTS_UDP="443,1443,8443"

# --- firewall backend: nftables (default on modern Ubuntu) or iptables ---
FWTYPE="nftables"

# --- optional automated test target: HOST:PORT of a peer node ---
# If set, `dpibypass test` auto-judges each strategy by TCP-connecting here
# (e.g. the peer's VLESS port). Leave empty to judge manually.
TEST_TARGET=""

# --- optional: restrict bypass to specific peer IPs (space-separated) ---
# Left empty = apply to all traffic on the ports above (recommended for
# dedicated VPN nodes where those ports ARE the tunnel). See README for the
# ipset-based narrowing if you share these ports with other services.
PEERS=""

# --- where this wrapper installs itself ---
DPIBYPASS_BASE="/opt/dpi-bypass"
